{
  "name": "promptmd-cli",
  "version": "1.1.0",
  "description": "CLI tool for running, chaining, and looping prompts defined in markdown files",
  "main": "dist/index.js",
  "bin": {
    "promd": "dist/cli.js",
    "promptmd": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "release": "semantic-release"
  },
  "keywords": [
    "cli",
    "prompt",
    "markdown",
    "ai"
  ],
  "author": "FreshlyBrewedCode",
  "repository": {
    "url": "https://github.com/FreshlyBrewedCode/promptmd"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.11.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.3.3"
  }
}
